# ── Discord ───────────────────────────────────────────────────────────────────
# Create bot at https://discord.com/developers/applications
# Enable: Message Content Intent, Server Members Intent
DISCORD_TOKEN=your-discord-bot-token-here

# Optional: your server (guild) ID for instant slash command sync
# Right-click your server name in Discord → Copy Server ID
# DISCORD_GUILD_ID=123456789012345678

# ── Claude (Anthropic API) ────────────────────────────────────────────────────
# Get key at https://console.anthropic.com — separate from Claude.ai subscription
ANTHROPIC_API_KEY=sk-ant-...

# Model to use — haiku is cheapest, sonnet is smarter, opus is most capable
# claude-haiku-4-5-20251001  →  fastest, ~$0.001 per message
# claude-sonnet-4-5          →  balanced, ~$0.01 per message
# claude-opus-4-6            →  most capable, ~$0.08 per message
CLAUDE_MODEL=claude-sonnet-4-5

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Claw's personality / system prompt
SYSTEM_PROMPT=You are Claw, a helpful and concise AI assistant. Keep replies short unless asked to elaborate.

# Max tokens per reply (higher = longer answers, more cost)
MAX_TOKENS=1024

# How many past messages to remember per channel (back-and-forth pairs)
MAX_MESSAGES_PER_CONV=40
